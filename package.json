{
  "name": "e2e-monitor",
  "version": "1.0.0",
  "description": "전반전부터 후반전까지, 당신의 터미널은 일하고 있었습니다.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild scripts/poll.ts --bundle --platform=node --format=esm --outfile=dist/poll.mjs",
    "list": "tsx scripts/poll.ts list",
    "daemon": "tsx scripts/poll.ts daemon",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
