{
  "name": "worldcup-live-cli",
  "version": "1.0.0",
  "description": "Watch football like you code — live World Cup commentary streamed into your Claude Code session.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild scripts/poll.ts --bundle --platform=node --format=esm --outfile=dist/poll.mjs",
    "list": "tsx scripts/poll.ts list",
    "daemon": "tsx scripts/poll.ts daemon",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
